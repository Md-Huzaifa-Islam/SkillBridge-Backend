# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/skillbridge?schema=public"

# Application URLs
BETTER_AUTH_URL="https://skillbridge-jet.vercel.app"

# Authentication (better-auth reads this automatically)
BETTER_AUTH_SECRET="your-super-secret-key-here-change-this-min-32-chars"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="SkillBridge <noreply@skillbridge.com>"

# Server Configuration
PORT="3000"
NODE_ENV="production"
